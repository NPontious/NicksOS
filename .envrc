# This script runs every time you enter the /etc/nixos directory.

# Silently fetch updates from the remote in the background
# This doesn't modify your local branch.
(git fetch --quiet &) >/dev/null 2>&1

# Check if we are behind the remote
UPSTREAM=${1:-'@{u}'}
LOCAL=$(git rev-parse @)
REMOTE=$(git rev-parse "$UPSTREAM")

if [ "$LOCAL" != "$REMOTE" ]; then
    # Check if we are actually behind (not just ahead)
    BASE=$(git merge-base @ "$UPSTREAM")
    if [ "$LOCAL" = "$BASE" ]; then
        echo -e "\033[0;33m⚠️  Updates available! Run 'git pull' to synchronize.\033[0m"
    fi
fi
