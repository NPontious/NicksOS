(git fetch --quiet &) >/dev/null 2>&1

# Determine the upstream branch
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)

if [ -n "$UPSTREAM" ]; then

    STATUS=$(git rev-list --left-right --count HEAD...$UPSTREAM 2>/dev/null)
    
    if [ -n "$STATUS" ]; then
        AHEAD=$(echo "$STATUS" | awk '{print $1}')
        BEHIND=$(echo "$STATUS" | awk '{print $2}')

        if [ "$BEHIND" -gt 0 ]; then
            if [ "$AHEAD" -gt 0 ]; then
                printf "\033[1;33mWarning:\033[0m Your branch has diverged from %%s ($AHEAD ahead, $BEHIND behind).\n" "$UPSTREAM" >&2
            else
                printf "\033[1;33mUpdates available:\033[0m Your branch is behind %%s by $BEHIND commit(s).\n" "$UPSTREAM" >&2
            fi
            printf "Run 'git pull --rebase' to update.\n" >&2
        fi
    fi
fi
